# Managed by Ansible (identity-ldap role)
# Root-only secrets for user management scripts.
LDAP_USERADMIN_PASSWORD={{ ldap_useradmin_password | to_json }}
SMTP_HOST={{ smtp_host | to_json }}
SMTP_PORT={{ (smtp_port | default(587, true) | int) | to_json }}
SMTP_USER={{ smtp_user | to_json }}
SMTP_PASSWORD={{ smtp_password | to_json }}
SMTP_FROM={{ (smtp_from | default(smtp_user, true)) | to_json }}
