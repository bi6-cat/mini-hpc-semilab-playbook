#!/bin/bash
# reset-hpc-user-password.sh — Reset password cho HPC user trong LDAP
# Usage: reset-hpc-user-password.sh <username>
#
# Script luôn tạo password ngẫu nhiên 8 ký tự và gửi qua email cho user.
#
# Requires (trong .env hoặc environment):
#   LDAP_USERADMIN_PASSWORD  — password của cn=hpc-useradmin
#   SMTP_HOST                — SMTP server để gửi email thông báo
#   SMTP_PORT                — mặc định 587
#   SMTP_USER                — tài khoản SMTP
#   SMTP_PASSWORD            — password SMTP
#   SMTP_FROM                — địa chỉ gửi (mặc định = SMTP_USER)

set -euo pipefail

# ─── Cấu hình LDAP ───────────────────────────────────────────────────────────
LDAP_URI="{{ ldap_server_uri }}"
ADMIN_DN="{{ ldap_useradmin_dn }}"
ADMIN_PASS="${LDAP_USERADMIN_PASSWORD:?LDAP_USERADMIN_PASSWORD not set}"
USER_BASE="{{ ldap_user_base }}"

# ─── Args ─────────────────────────────────────────────────────────────────────
USERNAME="${1:?Usage: $0 <username>}"

# ─── Validate username ────────────────────────────────────────────────────────
if ! [[ "$USERNAME" =~ ^[a-z][a-z0-9._-]{1,30}[a-z0-9]$|^[a-z]{1,3}$ ]]; then
  echo "ERROR: username không hợp lệ — bắt đầu bằng chữ thường, chỉ [a-z0-9._-], 3–32 ký tự"
  exit 1
fi

# ─── Kiểm tra user có tồn tại không ───────────────────────────────────────────
USER_LDIF="$(ldapsearch -LLL -x -H "$LDAP_URI" \
     -D "$ADMIN_DN" -w "$ADMIN_PASS" \
     -b "uid=${USERNAME},${USER_BASE}" -s base \
     "(objectClass=posixAccount)" dn cn mail 2>/dev/null || true)"

if ! echo "$USER_LDIF" | grep -q "^dn:"; then
  echo "ERROR: user '${USERNAME}' không tồn tại trong LDAP"
  exit 1
fi

# Extract user info
USER_CN="$(echo "$USER_LDIF" | awk '/^cn:/{$1=""; print $0}' | sed 's/^ //')"
USER_MAIL="$(echo "$USER_LDIF" | awk '/^mail:/{print $2}')"

# ─── Validate mail + SMTP config (bắt buộc) ─────────────────────────────────
if [ -z "${USER_MAIL:-}" ]; then
  echo "ERROR: user '${USERNAME}' chưa có thuộc tính mail trong LDAP"
  exit 1
fi

for required_var in SMTP_HOST SMTP_USER SMTP_PASSWORD; do
  if [ -z "${!required_var:-}" ]; then
    echo "ERROR: ${required_var} not set — cần cấu hình SMTP để gửi password reset"
    exit 1
  fi
done

# ─── Luôn tạo password ngẫu nhiên ────────────────────────────────────────────
NEW_PASS="$(LC_ALL=C tr -dc 'A-Za-z0-9!@#$%' < /dev/urandom | head -c 8 || true)"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "Reset password ngẫu nhiên cho user: ${USERNAME}"

# ─── Hiển thị thông tin user ──────────────────────────────────────────────────
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "Full name: ${USER_CN:-N/A}"
echo "Email    : ${USER_MAIL:-N/A}"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo ""
read -p "Xác nhận reset password? (y/N): " CONFIRM
if [ "$CONFIRM" != "y" ] && [ "$CONFIRM" != "Y" ]; then
  echo "Hủy bỏ."
  exit 0
fi

# ─── Cập nhật password vào LDAP (gửi plaintext, LDAP server tự hash) ─────────
ldapmodify -x -H "$LDAP_URI" -D "$ADMIN_DN" -w "$ADMIN_PASS" <<EOF
dn: uid=${USERNAME},${USER_BASE}
changetype: modify
replace: userPassword
userPassword: ${NEW_PASS}
-
replace: shadowLastChange
shadowLastChange: $(( $(date +%s) / 86400 ))
EOF

if [ $? -eq 0 ]; then
  echo "Password đã được reset thành công"
  echo ""
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo "NEW PASSWORD: ${NEW_PASS}"
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo ""
else
  echo "ERROR: Không thể reset password trong LDAP"
  exit 1
fi

# ─── Gửi email thông báo (bắt buộc) ──────────────────────────────────────────
MAIL_STATUS="FAILED"
SMTP_PORT="${SMTP_PORT:-587}"
SMTP_FROM="${SMTP_FROM:-${SMTP_USER}}"

EMAIL_SUBJECT="[HPC Lab] Password Reset - ${USERNAME}"
EMAIL_BODY="Hello ${USER_CN},

Your HPC account password has been reset by administrator.

Username: ${USERNAME}
New Password: ${NEW_PASS}

Please change your password after first login:
  ssh ${USERNAME}@login01.lab.local
  passwd

Best regards,
HPC Lab Admin Team"

# Gửi qua Python smtplib
if python3 -c "
import smtplib, ssl
from email.mime.text import MIMEText

msg = MIMEText('''${EMAIL_BODY}''')
msg['Subject'] = '''${EMAIL_SUBJECT}'''
msg['From'] = '''${SMTP_FROM}'''
msg['To'] = '''${USER_MAIL}'''

try:
    with smtplib.SMTP('''${SMTP_HOST}''', ${SMTP_PORT}, timeout=10) as server:
        server.starttls(context=ssl.create_default_context())
        server.login('''${SMTP_USER}''', '''${SMTP_PASSWORD}''')
        server.send_message(msg)
    print('Email sent to ${USER_MAIL}')
except Exception as e:
    print(f'Email failed: {e}')
    exit(1)
" 2>&1; then
  MAIL_STATUS="OK — sent to ${USER_MAIL}"
else
  echo " ERROR: LDAP password đã đổi nhưng gửi email thất bại."
  echo " Gửi password cho user qua kênh an toàn khác."
  exit 1
fi

# ─── Summary ──────────────────────────────────────────────────────────────────
echo ""
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "SUMMARY"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "Username      : ${USERNAME}"
echo "Full Name     : ${USER_CN:-N/A}"
echo "Email         : ${USER_MAIL:-N/A}"
echo "New Password  : ${NEW_PASS}"
echo "LDAP Update   : OK"
echo "Email Status  : ${MAIL_STATUS}"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo ""
echo "User đổi password ngay sau khi đăng nhập lần đầu."
echo ""
