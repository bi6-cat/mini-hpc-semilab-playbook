# slurmdbd.conf - Slurm Database Daemon configuration
# Generated by Ansible on {{ ansible_date_time.iso8601 }}
# DO NOT EDIT MANUALLY - Changes will be overwritten

# AUTHENTICATION
AuthType={{ slurmdbd_auth_type }}

# DATABASE CONNECTION
DbdHost={{ slurmdbd_host }}
DbdPort={{ slurmdbd_port }}
SlurmUser={{ slurm_user }}

# STORAGE BACKEND
StorageType=accounting_storage/mysql
StorageHost={{ slurm_db_host }}
StoragePort={{ slurm_db_port }}
StorageUser={{ slurm_db_user }}
StoragePass={{ mariadb_slurm_password }}
StorageLoc={{ slurm_db_name }}

# LOGGING
LogFile={{ slurmdbd_logfile }}
DebugLevel={{ slurmdbd_debug }}
PidFile={{ slurmdbd_pidfile }}

# ARCHIVE/PURGE
ArchiveEvents={{ slurmdbd_archive_events }}
ArchiveJobs={{ slurmdbd_archive_jobs }}
ArchiveSteps={{ slurmdbd_archive_steps }}
PurgeEventAfter={{ slurmdbd_purge_event }}
PurgeJobAfter={{ slurmdbd_purge_job }}
PurgeStepAfter={{ slurmdbd_purge_step }}
