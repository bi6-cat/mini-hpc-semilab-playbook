# slurm.conf - Slurm configuration file
# Generated by Ansible on {{ ansible_date_time.iso8601 }}
# DO NOT EDIT MANUALLY - Changes will be overwritten

# CLUSTER IDENTITY
ClusterName={{ slurm_cluster_name }}
SlurmctldHost={{ slurm_control_machine }}({{ slurm_control_addr }})
SlurmUser={{ slurm_user }}

# AUTHENTICATION
AuthType={{ slurm_auth_type }}
CryptoType={{ slurm_crypto_type }}

# ACCOUNTING STORAGE
AccountingStorageType={{ slurm_accounting_storage_type }}
AccountingStorageHost={{ slurm_accounting_storage_host }}
AccountingStoragePort={{ slurm_accounting_storage_port }}
AccountingStorageEnforce=associations,limits,qos

# SCHEDULING
SchedulerType={{ slurm_scheduler_type }}
SelectType={{ slurm_select_type }}
SelectTypeParameters={{ slurm_select_type_parameters }}

# PRIORITY
PriorityType=priority/multifactor
PriorityDecayHalfLife=7-0
PriorityMaxAge=7-0
PriorityWeightAge=1000
PriorityWeightFairshare=10000
PriorityWeightJobSize=1000
PriorityWeightPartition=1000
PriorityWeightQOS=10000

# LOGGING
SlurmctldDebug={{ slurm_slurmctld_debug }}
SlurmctldLogFile={{ slurm_slurmctld_logfile }}
SlurmdDebug={{ slurm_slurmd_debug }}
SlurmdLogFile={{ slurm_slurmd_logfile }}

# STATE PRESERVATION
StateSaveLocation={{ slurm_state_dir }}
SlurmdSpoolDir={{ slurm_slurmd_spool_dir }}
SlurmctldPidFile={{ slurm_run_dir }}/slurmctld.pid
SlurmdPidFile={{ slurm_run_dir }}/slurmd.pid

# PORTS
SlurmctldPort={{ slurm_slurmctld_port }}
SlurmdPort={{ slurm_slurmd_port }}

# TIMEOUTS
SlurmctldTimeout={{ slurm_slurmctld_timeout }}
SlurmdTimeout={{ slurm_slurmd_timeout }}
InactiveLimit={{ slurm_inactive_limit }}
MinJobAge={{ slurm_min_job_age }}
KillWait={{ slurm_kill_wait }}
Waittime={{ slurm_wait_time }}

# COMPLETION
CompleteWait={{ slurm_complete_wait }}
ReturnToService={{ slurm_return_to_service }}

# JOB LIMITS
MaxJobCount={{ slurm_max_job_count }}
MaxArraySize={{ slurm_max_array_size }}

# PROCESS TRACKING
ProctrackType=proctrack/cgroup
TaskPlugin=task/cgroup

# MPI
MpiDefault=none

# X11 FORWARDING
{% if slurm_x11_enabled | default(true) %}
PrologFlags=X11
{% endif %}

# RESOURCE LIMITS (from cgroups)
JobAcctGatherType=jobacct_gather/cgroup
JobAcctGatherFrequency=30

# COMPUTE NODES
{% if (slurm_compute_nodes | default([]) | length) > 0 %}
{% for node in slurm_compute_nodes %}
NodeName={{ node.name }} NodeAddr={{ node.addr }} CPUs={{ node.cpus }} RealMemory={{ node.memory }} State={{ node.state | default('UNKNOWN') }}
{% endfor %}
{% else %}
{% for node_name in groups['compute'] | default([]) %}
NodeName={{ node_name }} NodeAddr={{ hostvars[node_name]['ansible_host'] | default(node_name) }} CPUs={{ hostvars[node_name]['slurm_cpu_count'] | default(2) }} RealMemory={{ hostvars[node_name]['slurm_real_memory'] | default(4096) }} State=UNKNOWN
{% endfor %}
{% endif %}

# PARTITIONS
{% for partition in slurm_partitions %}
PartitionName={{ partition.name }} Nodes={{ partition.nodes }} Default={{ partition.default }} MaxTime={{ partition.max_time }} State={{ partition.state }}{% if partition.max_nodes is defined %} MaxNodes={{ partition.max_nodes }}{% endif %}

{% endfor %}
