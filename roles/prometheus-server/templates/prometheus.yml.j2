global:
  scrape_interval: {{ prometheus_scrape_interval }}
  evaluation_interval: {{ prometheus_evaluation_interval }}

scrape_configs:
  - job_name: 'prometheus'
    static_configs:
      - targets:
          - '127.0.0.1:{{ prometheus_port }}'

  - job_name: 'node-exporter'
    static_configs:
      - targets:
{% for host in (groups['head'] | default([]) + groups['login'] | default([]) + groups['compute'] | default([])) | unique %}
          - '{{ hostvars[host].ansible_host | default(host) }}:{{ node_exporter_port }}'
{% endfor %}
{% for host in (groups['storage'] | default([])) | unique %}
          - '{{ hostvars[host].ansible_host | default(host) }}:{{ node_exporter_port }}'
{% endfor %}

  - job_name: 'slurm-exporter'
    static_configs:
      - targets:
{% for host in (groups['head'] | default([])) | unique %}
          - '{{ hostvars[host].ansible_host | default(host) }}:{{ slurm_exporter_port }}'
{% endfor %}
