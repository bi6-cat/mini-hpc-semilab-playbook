# Copy this file to .env and fill real values
# cp .env.example .env && chmod 600 .env

# ── LDAP ─────────────────────────────────────────────────────────────────────
# Directory Manager password (dùng bởi Ansible playbooks để cấu hình 389-ds)
export LDAP_BIND_PASSWORD=change_me

# Optional: password cho test user hpc.test (mặc định = LDAP_BIND_PASSWORD)
export LDAP_TEST_USER_PASSWORD=change_me

# Scoped service account cho create/delete-hpc-user.sh
# KHÔNG dùng LDAP_BIND_PASSWORD — đây là credential riêng, quyền giới hạn
export LDAP_USERADMIN_PASSWORD=change_me

# ── Slurm DB ──────────────────────────────────────────────────────────────────
export MARIADB_ROOT_PASSWORD=change_me
export MARIADB_SLURM_PASSWORD=change_me

# ── SMTP (dùng bởi create-hpc-user.sh để gửi password qua email) ─────────────
# Ví dụ Gmail    : SMTP_HOST=smtp.gmail.com       SMTP_PORT=587  (dùng App Password)
# Ví dụ Office365: SMTP_HOST=smtp.office365.com   SMTP_PORT=587
export SMTP_HOST=smtp.example.com
export SMTP_PORT=587
export SMTP_USER=hpc-admin@example.com
export SMTP_PASSWORD=change_me
# Địa chỉ gửi hiển thị trong email (mặc định = SMTP_USER nếu bỏ trống)
export SMTP_FROM=hpc-noreply@example.com
