# LDAP (389-DS Directory Server)
# Dùng cho: ldap_bind_password, ldap_ds_root_password (all.yml)
export LDAP_BIND_PASSWORD=change_me

# MariaDB — Slurm accounting database (head.yml)
export MARIADB_ROOT_PASSWORD=change_me
export MARIADB_SLURM_PASSWORD=change_me

# Grafana admin login (roles/grafana-server)
export GRAFANA_ADMIN_PASSWORD=change_me

# Default password cho LDAP user tạo mới + ldap_admin_password
# Dùng cho: roles/user-privacy, roles/identity-ldap
export HPC_DEFAULT_USER_PASSWORD=change_me
